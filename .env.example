# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Deep Research

# ── Redis / Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Pipeline tuning (all optional — defaults shown) ───────────────────────────
PIPELINE_QUALITY_THRESHOLD=8
PIPELINE_MAX_ITERATIONS=4
PIPELINE_MAX_TARGETED_SEARCHES=2
PIPELINE_HOW_MANY_SEARCHES=5
PIPELINE_SEARCH_QUERY_CAP=5
PIPELINE_SCORE_GAP_THRESHOLD=4

# ── A2A agent endpoints (optional — change to split agents into separate containers) ──
A2A_BASE_URL=http://localhost:8000/a2a
# A2A_SEARCH_URL=http://search-service:8001/a2a/search
# A2A_ANALYST_URL=http://analyst-service:8002/a2a/analyst
# A2A_WRITER_URL=http://writer-service:8003/a2a/writer
# A2A_EVALUATOR_URL=http://evaluator-service:8004/a2a/evaluator

# ── MCP tool mode ─────────────────────────────────────────────────────────────
MCP_SEARCH_MODE=in-process    # or "http" for standalone MCP server
